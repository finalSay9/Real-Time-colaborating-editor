{
  "name": "collab-editor",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "client"
  ],
  "scripts": {
    "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "test": "docker compose -f docker-compose.test.yml up --abort-on-container-exit",
    "down": "docker compose down -v"
  }
}
